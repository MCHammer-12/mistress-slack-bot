# Slack (Mistress app)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Context repo — cloned on startup as the working directory
CONTEXT_REPO=https://github.com/MCHammer-12/the-mistress
BASE_DIRECTORY=/app/workspace

# Google Calendar credentials (paste JSON file contents as single-line strings)
GOOGLE_OAUTH_CREDENTIALS_JSON={"installed":{"client_id":"..."}}
GOOGLE_CALENDAR_TOKENS_JSON={"access_token":"...","refresh_token":"..."}